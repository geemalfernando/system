# Copy this file to .env and adjust values as needed.

# Storage backend:
# - local (default): saves data to a local JSON file under APP_DATA_DIR
# - mongo: uses MongoDB (requires DATABASE_URL)
STORAGE_BACKEND=local

# Local app data folder (where data.json + uploads live)
APP_DATA_DIR=~/.lion_car_sale

# MongoDB connection string (only needed if STORAGE_BACKEND=mongo)
DATABASE_URL=

# Optional: where uploaded receipt/document scans are stored (local folder)
UPLOAD_FOLDER=~/.lion_car_sale/uploads

# Optional: max upload size in MB (Flask will return 413 if exceeded)
MAX_CONTENT_LENGTH_MB=25
